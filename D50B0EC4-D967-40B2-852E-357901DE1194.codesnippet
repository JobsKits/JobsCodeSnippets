private lazy var dateYPicker: BRDatePicker = { [unowned self] in
    BRDatePicker()
        .byMode(.y) // 设置 Mode
        .bySelectDate(Date()) // 设置 Select Date
        .byToolbar { $0.byTitle(&quot;年份&quot;.tr).byCancelText(&quot;取消&quot;).byConfirmText(&quot;完成&quot;) } // 设置 Toolbar
        .byTheme { $0.byAutoSelect(false) } // 设置 Theme
        .byResult { [weak self] dt in // 设置 Result
            guard let self else { return }
            (&quot;自定义 Y：\(fmt(dt, &quot;yyyy&quot;))&quot;).toast
        }
}()
/// 日期：自定义 MD（月日）
private lazy var dateMDPicker: BRMonthDayPicker = { [unowned self] in
    BRMonthDayPicker()
        .bySelectDate(Date()) // 设置 Select Date
        .byToolbar { $0.byTitle(&quot;纪念日（月/日）&quot;.tr).byCancelText(&quot;取消&quot;).byConfirmText(&quot;完成&quot;) } // 设置 Toolbar
        .byTheme { $0.byAutoSelect(false) } // 设置 Theme
        .byResult { [weak self] dt in // 设置 Result
            guard let self else { return }
            (&quot;自定义 MD：\(fmt(dt, &quot;MM-dd&quot;))&quot;).toast
        }
}()
/// 日期：自定义 HM（时:分，步进 = 5）
private lazy var dateHMPicker: BRHourMinutePicker = { [unowned self] in
    BRHourMinutePicker()
        .byMinuteInterval(5) // 设置 Minute Interval
        .bySelectDate(Date()) // 设置 Select Date
        .byToolbar { $0.byTitle(&quot;提醒（时:分）&quot;.tr).byCancelText(&quot;取消&quot;).byConfirmText(&quot;完成&quot;) } // 设置 Toolbar
        .byTheme { $0.byAutoSelect(false) } // 设置 Theme
        .byResult { [weak self] dt in // 设置 Result
            guard let self else { return }
            (&quot;自定义 HM：\(fmt(dt, &quot;HH:mm&quot;))&quot;).toast
        }
}()</string>
	<key>IDECodeSnippetIdentifier</key>
	<string>D50B0EC4-D967-40B2-852E-357901DE1194</string>
	<key>IDECodeSnippetLanguage</key>
