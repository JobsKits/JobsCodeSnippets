                .byTapSound("Sound.wav") // 设置 Tap Sound
                .onTap { sender in // 绑定点按事件
                    print("🔔 向右间隔 · Banner 1 tapped, selected=\(sender.jobs_effectiveState == .selected)")
                    sender.title?.toast
                }
                .onLongPress(minimumPressDuration: 0.8) { btn, gr in // 绑定长按事件
                    if gr.state == .began {
                        btn.byAlpha(0.6)
                        print("长按开始 on \(btn)")
                    } else if gr.state == .ended || gr.state == .cancelled {
                        btn.byAlpha(1.0)
                        print("长按结束")
                    }
                },
