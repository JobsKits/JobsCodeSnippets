                .byBackgroundColor(JobsCor.systemIndigo.withAlphaComponent(0.2)) // 设置背景色
                .byTitle("向右间隔 · Banner 2") // 设置标题
                .byTitleColor(JobsCor.label) // 设置标题颜色
