<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
	<key>IDECodeSnippetCompletionPrefix</key>
	<string></string>
	<key>IDECodeSnippetCompletionScopes</key>
	<array>
		<string>All</string>
	</array>
	<key>IDECodeSnippetContents</key>
	<string>import JobsSwiftBaseDefines
import JobsMarqueeView

// MARK: - 1. 向上连续滚动
private lazy var upContinuousMarquee: JobsMarqueeView = { [unowned self] in
    JobsMarqueeView()
        .byDirection(.top) // 设置 Direction
        .byScrollMode(.continuous(speed: 40)) // 设置 Scroll Mode
        .byScrollMode(.frequency(interval: 1.0)) // 设置 Scroll Mode
        .byItemSizeMode(.fitContent)   // 典型公告跑马灯
        .byDataSourceButtons([ // 设置 Data Source Buttons
            UIButton.sys()
                .byBackgroundColor(JobsCor.systemYellow.withAlphaComponent(0.2)) // 设置背景色
                .byTitle("向上连续 · 公告 1") // 设置标题
                .byTitleColor(JobsCor.label) // 设置标题颜色
                .byTitleFont(JobsFont.systemFont(ofSize: 14, weight: .medium)) // 设置标题字体
                .bySubTitle("更多内容 1") // 设置副标题
                .bySubTitleColor(JobsCor.secondaryLabel) // 设置副标题颜色
                .bySubTitleFont(JobsFont.systemFont(ofSize: 11, weight: .regular)) // 设置 Sub Title Font
                .byImage("megaphone.fill".sysImg) // 设置图片
                .byContentEdgeInsets(UIEdgeInsets(top: 4, left: 8, bottom: 4, right: 8)) // 设置内容边距
                .byTitleEdgeInsets(UIEdgeInsets(top: 0, left: 6, bottom: 0, right: -6)) // 设置标题边距
                .byTapSound("Sound.wav") // 设置 Tap Sound
                .onTap { sender in // 绑定点按事件
                    print("🔔 向上连续 · 公告 1 tapped, selected=\(sender.jobs_effectiveState == .selected)")
                    sender.title?.toast
                }
                .onLongPress(minimumPressDuration: 0.8) { btn, gr in // 绑定长按事件
                    if gr.state == .began {
                        btn.byAlpha(0.6)
                        print("长按开始 on \(btn)")
                    } else if gr.state == .ended || gr.state == .cancelled {
                        btn.byAlpha(1.0)
                        print("长按结束")
                    }
                },
            UIButton.sys()
                .byBackgroundColor(JobsCor.systemYellow.withAlphaComponent(0.2)) // 设置背景色
                .byTitle("向上连续 · 公告 2") // 设置标题
                .byTitleColor(JobsCor.label) // 设置标题颜色
                .byTitleFont(JobsFont.systemFont(ofSize: 14, weight: .medium)) // 设置标题字体
                .bySubTitle("更多内容 2") // 设置副标题
                .bySubTitleColor(JobsCor.secondaryLabel) // 设置副标题颜色
                .bySubTitleFont(JobsFont.systemFont(ofSize: 11, weight: .regular)) // 设置 Sub Title Font
                .byImage("megaphone.fill".sysImg) // 设置图片
                .byContentEdgeInsets(UIEdgeInsets(top: 4, left: 8, bottom: 4, right: 8)) // 设置内容边距
                .byTitleEdgeInsets(UIEdgeInsets(top: 0, left: 6, bottom: 0, right: -6)) // 设置标题边距
                .byTapSound("Sound.wav") // 设置 Tap Sound
                .onTap { sender in // 绑定点按事件
                    print("🔔 向上连续 · 公告 2 tapped, selected=\(sender.jobs_effectiveState == .selected)")
                    sender.title?.toast
                }
                .onLongPress(minimumPressDuration: 0.8) { btn, gr in // 绑定长按事件
                    if gr.state == .began {
                        btn.byAlpha(0.6)
                        print("长按开始 on \(btn)")
                    } else if gr.state == .ended || gr.state == .cancelled {
                        btn.byAlpha(1.0)
                        print("长按结束")
                    }
                },
            UIButton.sys()
                .byBackgroundColor(JobsCor.systemYellow.withAlphaComponent(0.2)) // 设置背景色
                .byTitle("向上连续 · 公告 3") // 设置标题
                .byTitleColor(JobsCor.label) // 设置标题颜色
                .byTitleFont(JobsFont.systemFont(ofSize: 14, weight: .medium)) // 设置标题字体
                .bySubTitle("更多内容 3") // 设置副标题
                .bySubTitleColor(JobsCor.secondaryLabel) // 设置副标题颜色
                .bySubTitleFont(JobsFont.systemFont(ofSize: 11, weight: .regular)) // 设置 Sub Title Font
                .byImage("megaphone.fill".sysImg) // 设置图片
                .byContentEdgeInsets(UIEdgeInsets(top: 4, left: 8, bottom: 4, right: 8)) // 设置内容边距
                .byTitleEdgeInsets(UIEdgeInsets(top: 0, left: 6, bottom: 0, right: -6)) // 设置标题边距
                .byTapSound("Sound.wav") // 设置 Tap Sound
                .onTap { sender in // 绑定点按事件
                    print("🔔 向上连续 · 公告 3 tapped, selected=\(sender.jobs_effectiveState == .selected)")
                    sender.title?.toast
                }
                .onLongPress(minimumPressDuration: 0.8) { btn, gr in // 绑定长按事件
                    if gr.state == .began {
                        btn.byAlpha(0.6)
                        print("长按开始 on \(btn)")
                    } else if gr.state == .ended || gr.state == .cancelled {
                        btn.byAlpha(1.0)
                        print("长按结束")
                    }
                }
        ])
        .byBackgroundColor(.randomColor) // 设置背景色
        /// 加载到目标视图上，并第一次配置新约束
        .byAddTo(view) {[unowned self] make in // 加入父视图并部署约束
            if view.jobs_hasVisibleTopBar() {
                make.top.equalTo(self.gk_navigationBar.snp.bottom).offset(10)
                make.left.right.bottom.equalToSuperview()
            } else {
                make.edges.equalToSuperview()
            }
         }
        ///（并未加载到目标视图上）第一次部署新约束
        .byMakeConstraints { [unowned self] make in // 部署约束
            make.width.height.equalTo(AD(76))
        }
        /// 只修改某一条约束，其余约束不动
        .byUpdateConstraints { [unowned self] make in // 更新约束
            make.top.equalToSuperview().inset(8.h)
        }
        /// 清除以前的全部的旧约束，用目前最新的
        .byRemakeConstraints { [unowned self] make in // 重建约束
            make.top.equalTo(wrapperImgView.snp.bottom).offset(20.h)
            make.left.equalTo(scrollView.frameLayoutGuide.snp.left).offset(20.w)
            make.right.equalTo(scrollView.frameLayoutGuide.snp.right).inset(20.w)
            make.height.equalTo(180.h)
        }
}()
