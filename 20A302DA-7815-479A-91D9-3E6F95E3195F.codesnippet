private lazy var kingfisherImageButtonsMarquee: JobsMarqueeView = { [unowned self] in
    JobsMarqueeView()
        .byDirection(.left) // 设置 Direction
        .byScrollMode(.continuous(speed: 60)) // 设置 Scroll Mode
        .byScrollMode(.frequency(interval: 1.0)) // 设置 Scroll Mode
        .byItemSizeMode(.fillBounds) // 设置 Item Size Mode
        .byManualScrollEnabled(true)   // ✅ 开启手动拖拽
        .byDataSourceButtons ([ // 设置 Data Source Buttons
            UIButton.sys()
                .byTitle("我是UIButton主标题@Kingfisher").byTitleColor(JobsCor.red) // 设置标题
                .bySubTitle("我是UIButton副标题@Kingfisher").bySubTitleColor(JobsCor.yellow) // 设置副标题
                .kf_imageURL("https://picsum.photos/" + ScreenWidth().toString(0) + "/" + self.marqueeHeight.toString(0))
                .kf_placeholderImage("唐老鸭".img) // 配置链式能力
                .kf_options([ // 配置链式能力
                    .processor(DownsamplingImageProcessor(size: CGSize(width: 500, height: 200))), // 配置链式能力
                    .scaleFactor(UIScreen.main.scale), // 配置链式能力
                    .cacheOriginalImage, // 配置链式能力
                    .transition(.fade(0.25)), // 配置链式能力
                    .retryStrategy(DelayRetryStrategy(maxRetryCount: 2, retryInterval: .seconds(1))) // 配置链式能力
                ])
                .kf_bgNormalLoad()// 之前是配置项，这里才是真正决定渲染背景图/前景图
                .byTapSound("Sound.wav") // 设置 Tap Sound
                .onTap { sender in // 绑定点按事件
                    print("🔴 Kingfisher@背景图 1 tapped, selected=\(sender.jobs_effectiveState == .selected)")
                    "点击了Kingfisher@背景图".toast
                }
                .onLongPress(minimumPressDuration: 0.8) { btn, gr in // 绑定长按事件
                    if gr.state == .began {
                        btn.byAlpha(0.6)
                        print("长按开始 on \(btn)")
                    } else if gr.state == .ended || gr.state == .cancelled {
                        btn.byAlpha(1.0)
                        print("长按结束")
                    }
                },
            UIButton.sys()
                .byTitle("我是UIButton主标题@Kingfisher").byTitleColor(JobsCor.red) // 设置标题
